# Copy to .env and fill in values

# API auth — must match NEFKE_API_KEY in Vercel env vars
INTERNAL_CHAT_KEY=change-me-generate-with-openssl-rand-hex-32

# Supabase — for RAG knowledge base (optional but recommended)
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Model overrides (defaults work after model-init runs)
CHAT_MODEL=nefke-q4_k_m
FALLBACK_MODEL=nefke-q4_k_m
EMBEDDING_MODEL=nomic-embed-text

# Cloudflare named tunnel (optional — leave blank for quick-tunnel)
# Get token from: https://dash.cloudflare.com/ > Zero Trust > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
